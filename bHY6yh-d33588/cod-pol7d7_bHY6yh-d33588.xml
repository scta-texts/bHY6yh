      <body>
         <div xml:id="bHY6yh-d33588"><!-- p2l4-r5 -->
            <head xml:id="bHY6yh-d33588-Hd1e108">Rubrica 5</head>
            <head xml:id="bHY6yh-d33588-Hd1e111" type="question-title">De discordia</head>
            <p xml:id="bHY6yh-d33588-d1e114">
              <lb ed="#K" n="34"/>De discordia Rubrica quinta
            </p>
            <p xml:id="bHY6yh-d33588-d1e119">
              <lb ed="#K" n="35"/> ¶ <ref>Salomon in prouerbiis capitulo 30</ref> /<quote xml:id="bHY6yh-d33588-Qd1e123">Qui 
              <lb ed="#K" n="36"/>prouocat iras producit discor<lb ed="#K" break="no" n="37"/>dias</quote>
            </p>
            <p xml:id="bHY6yh-d33588-d1e131">
                <cb ed="#K" n="b"/>
              <lb ed="#K" n="38"/> ¶<ref xml:id="bHY6yh-d33588-Rd1e128">Salustius in iugurtio</ref> <quote xml:id="bHY6yh-d33588-Qd1e135">Con<lb ed="#K" break="no" n="39"/>cordia
              parue res crescunt discor<lb ed="#K" break="no" n="40"/>dia 
              maxime dilabuntur</quote>
            </p>
            <p xml:id="bHY6yh-d33588-d1e142">
              <lb ed="#K" n="41"/> ¶<ref xml:id="bHY6yh-d33588-Rd1e141">Tullius de amincitia</ref> /<quote xml:id="bHY6yh-d33588-Qd1e146">Que domus tam 
              <lb ed="#K" n="42"/>stabilis que ciuitas tam 
              <lb ed="#K" n="43"/>firma est que non odiis et dissidiis 
              <lb ed="#K" n="44"/>funditus possit euerti</quote>
            </p>
            <p xml:id="bHY6yh-d33588-d1e154">
              <lb ed="#K" n="45"/> ¶<ref xml:id="bHY6yh-d33588-Rd1e155">Iacobus apostolus epistola vnica capitulo 4</ref> <quote xml:id="bHY6yh-d33588-Qd1e158">Unde 
              <lb ed="#K" n="46"/>bella et lites intur vos hinc 
              <lb ed="#K" n="47"/>nonne ex concupiscentiis vestris qui 
              <lb ed="#K" n="48"/>militant in membris vestris</quote>
            </p>
            <p xml:id="bHY6yh-d33588-d1e166">
              <lb ed="#K" n="49"/> ¶<ref xml:id="bHY6yh-d33588-Rd1e169">Paulus apostolus epistola ad galathas capitulo 5</ref> <quote xml:id="bHY6yh-d33588-Qd1e170">Si 
              <lb ed="#K" n="50"/>inuicem mordetis et comeditis vide<lb ed="#K" break="no" n="51"/>te 
              ne abinuicem consumamini</quote>
            </p>
            <p xml:id="bHY6yh-d33588-d1e178">
              <lb ed="#K" n="52"/> ¶<ref xml:id="bHY6yh-d33588-Rd1e183">Lex diges ti de arb libro item sisinnus 
              <lb ed="#K" n="53"/>capitulo fi</ref> <quote xml:id="bHY6yh-d33588-Qd1e182">namlis facilitas hominum est 
              <lb ed="#K" n="54"/>ad dissentiendum</quote>
            </p>
            <p xml:id="bHY6yh-d33588-d1e188">
              <ref xml:id="bHY6yh-d33588-Rd1e193">ti deserui 
              <lb ed="#K" n="55"/>vr praedi libro in re communi</ref> <quote xml:id="bHY6yh-d33588-Qd1e190">Propter 
              <lb ed="#K" n="56"/>imensas contentiones plerumque 
              <lb ed="#K" n="57"/>res ad diuisionem peruenit</quote>
            </p>
            <p xml:id="bHY6yh-d33588-d1e198">
              <ref xml:id="bHY6yh-d33588-Rd1e206">ti 
              <lb ed="#K" n="58"/>de le ii libro cum psaltur § dulcis<lb ed="#K" break="no" n="59"/>simis</ref> 
              <quote xml:id="bHY6yh-d33588-Qd1e200">communio solet ecitare discor<lb ed="#K" break="no" n="60"/>dias</quote>
            </p>
            <p xml:id="bHY6yh-d33588-d1e209">
              <lb ed="#K" n="61"/> ¶<ref xml:id="bHY6yh-d33588-Rd1e222">prudentius de psicomachia capitulo 10</ref> <quote xml:id="bHY6yh-d33588-Qd1e213">nil dissociabile firmum est</quote>
            </p>
            <p xml:id="bHY6yh-d33588-d1e225">
              <lb ed="#K" n="62"/> ¶<ref xml:id="bHY6yh-d33588-Rd1e240">prosper sub vlt capitulo</ref> <quote xml:id="bHY6yh-d33588-Qd1e229">undique bella fre<lb ed="#K" break="no" n="63"/>munt 
              omnes furor excitat a<lb ed="#K" break="no" n="64"/>rmis 
              Incumbunt reges regi<lb ed="#K" break="no" n="65"/>bus 
              innumeris Impia confuso seuit 
              <lb ed="#K" n="66"/>discordia mundo Pax abiit 
              <lb ed="#K" n="67"/>terris</quote>
            </p>
            <p xml:id="bHY6yh-d33588-d1e241">
              <lb ed="#K" n="68"/> ¶<ref xml:id="bHY6yh-d33588-Rd1e258">Boetius de consolatione libro 4 capitulo xi</ref> <quote xml:id="bHY6yh-d33588-Qd1e245">ut probis atque improbis nullum 
              <lb ed="#K" n="69"/>fedus est ita ipsi inter se im<lb ed="#K" break="no" n="70"/>probi 
              nequeunt conuenire qui<lb ed="#K" break="no" n="71"/>d 
              ni cum a semetipsis discrepan<lb ed="#K" break="no" n="72"/>tibus 
              conscientia vitiis improbi quique 
              <lb ed="#K" n="73"/>dissentiant</quote>
            </p>
            <p xml:id="bHY6yh-d33588-d1e257">
              <lb ed="#K" n="74"/> /<ref xml:id="bHY6yh-d33588-Rd1e276">Gregorius in pastorali capitulo 48</ref> <quote xml:id="bHY6yh-d33588-Qd1e261">omnes qui per 
                  <pb ed="#K" n="75-v"/>
                  <cb ed="#K" n="a"/>
              <lb ed="#K" n="1"/>discordiam separantur a viridita<lb ed="#K" break="no" n="2"/>te 
              dilectionis arescunt</quote>
            </p>
            <p xml:id="bHY6yh-d33588-d1e269">
              <lb ed="#K" n="3"/> ¶<ref xml:id="bHY6yh-d33588-Rd1e290">Prouerb vulgis</ref> <quote xml:id="bHY6yh-d33588-Qd1e273">la guerra alarga en<lb ed="#K" break="no" n="4"/>tra 
              et strecta en sua</quote>
            </p>
         </div>
      </body>
